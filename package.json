{
  "name": "memoapp",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "build": {
    "appId": "com.memo.app",
    "productName": "备忘录",
    "artifactName": "${productName}.${ext}",
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "forceCodeSigning": false,
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}